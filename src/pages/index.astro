---
import BaseLayout from '../layouts/BaseLayout.astro';

const navCards = [
  {
    title: 'Docs',
    href: '/docs/',
    description: 'Architecture, brand manual & project guides',
  },
  {
    title: 'Performance',
    href: '/performance/',
    description: 'System health, latency & API metrics',
  },
  {
    title: 'Projects',
    href: '/projects/',
    description: 'Access DaisyChain tools and applications',
  },
  {
    title: 'Admin',
    href: '/admin/',
    description: 'Manage users and team access',
  },
];
---

<BaseLayout title="Home" description="DaisyChain — tools and project hub">
  <div class="hub">
    <div class="hub-header">
      <h1 class="hub-title">DaisyChain</h1>
      <p class="hub-subtitle">Tools & project hub</p>
    </div>

    <div class="hub-grid">
      {navCards.map((card) => (
        <a href={card.href} class="hub-card">
          <span class="hub-card-title">{card.title}</span>
          <p class="hub-card-desc">{card.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .hub {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    padding: 3rem 0 2rem;
  }

  .hub-header {
    text-align: center;
  }

  .hub-title {
    font-family: var(--font-mono);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    margin: 0 0 0.5rem;
    line-height: 1.1;
  }

  .hub-subtitle {
    color: var(--muted-foreground);
    font-size: 1rem;
    margin: 0;
  }

  .hub-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    width: 100%;
    max-width: 640px;
  }

  .hub-card {
    padding: 1.5rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    backdrop-filter: blur(12px);
    text-decoration: none;
    color: var(--foreground);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .hub-card:hover {
    border-color: hsl(300 60% 40%);
    box-shadow: 0 0 24px hsl(300 100% 60% / 0.15);
  }

  .hub-card-title {
    font-weight: 600;
    font-size: 1.0625rem;
  }

  .hub-card-desc {
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 500px) {
    .hub-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
