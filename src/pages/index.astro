---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../config/projects';
---

<BaseLayout title="Home" description="DaisyChain — tools and project hub">
  <section class="hero">
    <h1 class="hero-title">DaisyChain</h1>
    <p class="hero-subtitle">
      Internal tools and project hub.
    </p>
    <div class="hero-actions">
      <a href="/projects/" class="btn btn-primary">All projects</a>
    </div>
  </section>

  {projects.length > 0 && (
    <section class="preview-section">
      <h2 class="section-title">Projects</h2>
      <div class="project-grid">
        {projects.slice(0, 3).map((p) => (
          <div class="project-card" data-project-id={p.id}>
            <div class="card-header">
              <a
                href={p.href}
                class="project-name"
                target={p.external ? '_blank' : undefined}
                rel={p.external ? 'noopener noreferrer' : undefined}
              >
                {p.name}
                {p.external && <span class="external-arrow" aria-hidden="true">&#8599;</span>}
              </a>
              <span
                class="status-dot"
                data-status-url={p.statusUrl || p.href}
                title="Checking..."
              />
            </div>
            <p class="project-desc">{p.description}</p>
            {p.details && (
              <details class="project-details">
                <summary>About this project</summary>
                <p class="details-body">{p.details}</p>
              </details>
            )}
          </div>
        ))}
      </div>
      <a href="/projects/" class="link-more">View all projects &rarr;</a>
    </section>
  )}

  {projects.length === 0 && (
    <section class="empty-state">
      <p class="empty-text">No projects configured yet.</p>
      <p class="empty-hint">
        Add entries to <code>src/config/projects.config.ts</code> to list your projects here.
      </p>
    </section>
  )}
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll<HTMLElement>('.status-dot[data-status-url]').forEach(async (dot) => {
      const url = dot.dataset.statusUrl!;
      try {
        const isExternal = url.startsWith('http');
        const resp = await fetch(url, {
          method: 'HEAD',
          mode: isExternal ? 'no-cors' : 'same-origin',
          cache: 'no-store',
        });
        // no-cors gives opaque response (type "opaque", status 0) on success
        if (resp.ok || resp.type === 'opaque') {
          dot.classList.add('status-up');
          dot.title = 'Online';
        } else {
          dot.classList.add('status-down');
          dot.title = 'Unreachable';
        }
      } catch {
        dot.classList.add('status-down');
        dot.title = 'Unreachable';
      }
    });
  });
</script>

<style>
  .hero {
    margin-bottom: 3rem;
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .hero-subtitle {
    color: var(--muted-foreground);
    font-size: 1rem;
    max-width: 36ch;
    margin: 0 0 1.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
  }

  .preview-section {
    margin-top: 2.5rem;
  }

  .section-title {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted-foreground);
    margin: 0 0 1rem;
  }

  /* ── Cards ─────────────────────────────────── */
  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .project-card {
    padding: 1.25rem 1.5rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    backdrop-filter: blur(12px);
    transition: border-color 0.15s ease;
  }

  .project-card:hover {
    border-color: hsl(260 30% 35%);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--foreground);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .project-name:hover {
    color: var(--primary);
  }

  .external-arrow {
    font-size: 0.75rem;
    opacity: 0.5;
    margin-left: 0.25rem;
  }

  .project-desc {
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  /* ── Status dot ────────────────────────────── */
  .status-dot {
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--muted);
    transition: background 0.3s ease;
  }

  .status-dot.status-up {
    background: #22c55e;
  }

  .status-dot.status-down {
    background: #ef4444;
  }

  /* ── Expandable details ────────────────────── */
  .project-details {
    border-top: 1px solid var(--border);
    padding-top: 0.625rem;
    margin-top: 0.25rem;
  }

  .project-details summary {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted-foreground);
    cursor: pointer;
    user-select: none;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .project-details summary::-webkit-details-marker {
    display: none;
  }

  .project-details summary::before {
    content: '>';
    font-family: var(--font-mono);
    font-size: 0.625rem;
    transition: transform 0.15s ease;
    display: inline-block;
  }

  .project-details[open] summary::before {
    transform: rotate(90deg);
  }

  .details-body {
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    line-height: 1.6;
    margin: 0.5rem 0 0;
  }

  /* ── Misc ──────────────────────────────────── */
  .link-more {
    display: inline-block;
    margin-top: 1.25rem;
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .link-more:hover {
    color: var(--foreground);
  }

  .empty-state {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: var(--card);
    border: 1px dashed var(--border);
    border-radius: var(--radius-md);
  }

  .empty-text {
    margin: 0 0 0.5rem;
    color: var(--muted-foreground);
  }

  .empty-hint {
    margin: 0;
    font-size: 0.875rem;
    color: var(--muted-foreground);
  }

  .empty-hint code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 0.15em 0.4em;
    background: var(--muted);
    border-radius: var(--radius-sm);
  }
</style>
