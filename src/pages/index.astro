---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../config/projects';
---

<BaseLayout title="Home" description="Dev tools and project hub">
  <section class="hero">
    <h1 class="hero-title">Tools & project dev</h1>
    <p class="hero-subtitle">
      A hub for development tools and projects. Sign in to access your workspace, or browse public projects below.
    </p>
    <div class="hero-actions">
      <a href="/projects/" class="btn btn-primary">View projects</a>
      <a href="/login/" class="btn btn-ghost">Sign in</a>
    </div>
  </section>

  {projects.length > 0 && (
    <section class="preview-section">
      <h2 class="section-title">Featured projects</h2>
      <div class="project-grid">
        {projects.slice(0, 3).map((p) => (
          <a
            href={p.href}
            class="project-card"
            target={p.external ? '_blank' : undefined}
            rel={p.external ? 'noopener noreferrer' : undefined}
          >
            <span class="project-name">{p.name}</span>
            <span class="project-desc">{p.description}</span>
            {p.external && <span class="project-badge">external</span>}
          </a>
        ))}
      </div>
      <a href="/projects/" class="link-more">View all projects →</a>
    </section>
  )}

  {projects.length === 0 && (
    <section class="empty-state">
      <p class="empty-text">No projects configured yet.</p>
      <p class="empty-hint">
        Add entries to <code>src/config/projects.ts</code> to list your projects here.
      </p>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    margin-bottom: 3rem;
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
    line-height: 1.2;
  }

  .hero-subtitle {
    color: var(--muted-foreground);
    font-size: 1rem;
    max-width: 36ch;
    margin: 0 0 1.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
  }

  .preview-section {
    margin-top: 2.5rem;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted-foreground);
    margin: 0 0 1rem;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }

  .project-card {
    display: block;
    padding: 1.5rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition);
    backdrop-filter: blur(12px);
  }

  .project-card:hover {
    border-color: var(--primary);
    box-shadow: 0 0 20px var(--primary-glow);
  }

  .project-name {
    display: block;
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 0.35rem;
  }

  .project-desc {
    font-size: 0.875rem;
    color: var(--muted-foreground);
  }

  .project-badge {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--secondary);
    text-transform: uppercase;
    border: 1px solid var(--secondary);
    border-radius: var(--radius-sm);
  }

  .link-more {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--primary);
    text-decoration: none;
    transition: color var(--transition);
  }

  .link-more:hover {
    color: var(--secondary);
    text-shadow: 0 0 12px hsl(180 100% 50% / 0.5);
  }

  .empty-state {
    margin-top: 2.5rem;
    padding: 1.5rem;
    background: var(--card);
    border: 1px dashed var(--border);
    border-radius: var(--radius-md);
  }

  .empty-text {
    margin: 0 0 0.5rem;
    color: var(--muted-foreground);
  }

  .empty-hint {
    margin: 0;
    font-size: 0.875rem;
    color: var(--muted-foreground);
  }

  .empty-hint code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 0.15em 0.4em;
    background: var(--muted);
    border-radius: var(--radius-sm);
  }
</style>
