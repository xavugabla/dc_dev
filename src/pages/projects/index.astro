---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../config/projects';
---

<BaseLayout title="Projects" description="DaisyChain projects">
  <section class="projects-section">
    <h1 class="projects-title">Projects</h1>
    <p class="projects-subtitle">Active tools and services.</p>

    {projects.length > 0 ? (
      <ul class="project-list">
        {projects.map((p) => (
          <li class="project-item" data-project-id={p.id}>
            <div class="item-row">
              <span
                class="status-dot"
                data-status-url={p.statusUrl || p.href}
                title="Checking..."
              />
              <a
                href={p.href}
                class="project-link-name"
                target={p.external ? '_blank' : undefined}
                rel={p.external ? 'noopener noreferrer' : undefined}
              >
                {p.name}
                {p.external && <span class="external-arrow" aria-hidden="true">&#8599;</span>}
              </a>
              <span class="project-link-desc">{p.description}</span>
            </div>
            {p.details && (
              <details class="project-details">
                <summary>About this project</summary>
                <p class="details-body">{p.details}</p>
              </details>
            )}
          </li>
        ))}
      </ul>
    ) : (
      <div class="empty-projects">
        <p>No projects added yet.</p>
        <p class="empty-hint">
          Edit <code>src/config/projects.ts</code> to get started.
        </p>
      </div>
    )}
  </section>

  <hr class="divider" />

  <section class="docs-section">
    <h2 class="docs-title">Adding a new project</h2>
    <p class="docs-body">
      All projects are defined in a single file:
      <code>src/config/projects.ts</code>
    </p>
    <ol class="docs-steps">
      <li>
        Open <code>src/config/projects.ts</code> and add an entry to the
        <code>projects</code> array:
        <pre class="docs-code"><code>{`{
  id: 'my-tool',
  name: 'My Tool',
  description: 'Short one-liner for the card',
  href: '/api/my-tool',        // or an external URL
  external: true,              // optional — opens in new tab
  statusUrl: 'https://...',    // optional — health-check URL
  details: 'Longer explanation shown when the user expands the card.',
}`}</code></pre>
      </li>
      <li>
        The project appears automatically on the home page (first 3) and on
        this page.
      </li>
      <li>
        If you provide a <code>statusUrl</code> (or leave it out to default to
        <code>href</code>), a health-check dot will ping that URL on page load
        and show green/red status.
      </li>
    </ol>

    <h3 class="docs-subtitle">Field reference</h3>
    <div class="docs-table-wrap">
      <table class="docs-table">
        <thead>
          <tr>
            <th>Field</th>
            <th>Type</th>
            <th>Required</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          <tr><td><code>id</code></td><td>string</td><td>Yes</td><td>Unique slug (kebab-case)</td></tr>
          <tr><td><code>name</code></td><td>string</td><td>Yes</td><td>Display name</td></tr>
          <tr><td><code>description</code></td><td>string</td><td>Yes</td><td>Short tagline</td></tr>
          <tr><td><code>href</code></td><td>string</td><td>Yes</td><td>URL or path to the project</td></tr>
          <tr><td><code>external</code></td><td>boolean</td><td>No</td><td>If true, link opens in new tab</td></tr>
          <tr><td><code>statusUrl</code></td><td>string</td><td>No</td><td>URL to ping for health check (defaults to href)</td></tr>
          <tr><td><code>details</code></td><td>string</td><td>No</td><td>Longer explanation for the expandable section</td></tr>
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll<HTMLElement>('.status-dot[data-status-url]').forEach(async (dot) => {
      const url = dot.dataset.statusUrl!;
      try {
        const isExternal = url.startsWith('http');
        const resp = await fetch(url, {
          method: 'HEAD',
          mode: isExternal ? 'no-cors' : 'same-origin',
          cache: 'no-store',
        });
        if (resp.ok || resp.type === 'opaque') {
          dot.classList.add('status-up');
          dot.title = 'Online';
        } else {
          dot.classList.add('status-down');
          dot.title = 'Unreachable';
        }
      } catch {
        dot.classList.add('status-down');
        dot.title = 'Unreachable';
      }
    });
  });
</script>

<style>
  .projects-section {
    max-width: 720px;
  }

  .projects-title {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0 0 0.375rem;
  }

  .projects-subtitle {
    color: var(--muted-foreground);
    font-size: 0.875rem;
    margin: 0 0 1.5rem;
  }

  /* ── Project list ──────────────────────────── */
  .project-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-item {
    padding: 1rem 1.25rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    backdrop-filter: blur(12px);
    transition: border-color 0.15s ease;
  }

  .project-item:hover {
    border-color: hsl(260 30% 35%);
  }

  .item-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .project-link-name {
    font-weight: 600;
    font-size: 0.9375rem;
    min-width: 120px;
    color: var(--foreground);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .project-link-name:hover {
    color: var(--primary);
  }

  .external-arrow {
    font-size: 0.75rem;
    opacity: 0.5;
    margin-left: 0.2rem;
  }

  .project-link-desc {
    flex: 1;
    font-size: 0.8125rem;
    color: var(--muted-foreground);
  }

  /* ── Status dot ────────────────────────────── */
  .status-dot {
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--muted);
    transition: background 0.3s ease;
  }

  .status-dot.status-up {
    background: #22c55e;
  }

  .status-dot.status-down {
    background: #ef4444;
  }

  /* ── Expandable details ────────────────────── */
  .project-details {
    border-top: 1px solid var(--border);
    padding-top: 0.625rem;
    margin-top: 0.75rem;
  }

  .project-details summary {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted-foreground);
    cursor: pointer;
    user-select: none;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .project-details summary::-webkit-details-marker {
    display: none;
  }

  .project-details summary::before {
    content: '>';
    font-family: var(--font-mono);
    font-size: 0.625rem;
    transition: transform 0.15s ease;
    display: inline-block;
  }

  .project-details[open] summary::before {
    transform: rotate(90deg);
  }

  .details-body {
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    line-height: 1.6;
    margin: 0.5rem 0 0;
  }

  /* ── Divider ───────────────────────────────── */
  .divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3rem 0 2.5rem;
  }

  /* ── Docs section ──────────────────────────── */
  .docs-section {
    max-width: 720px;
  }

  .docs-title {
    font-family: var(--font-mono);
    font-size: 1.125rem;
    font-weight: 500;
    margin: 0 0 0.75rem;
  }

  .docs-subtitle {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    margin: 1.5rem 0 0.75rem;
  }

  .docs-body {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    line-height: 1.6;
    margin: 0 0 1rem;
  }

  .docs-body code,
  .docs-steps code {
    font-family: var(--font-mono);
    font-size: 0.8em;
    padding: 0.15em 0.4em;
    background: var(--muted);
    border-radius: var(--radius-sm);
  }

  .docs-steps {
    padding-left: 1.25rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--muted-foreground);
    line-height: 1.6;
  }

  .docs-code {
    margin: 0.5rem 0 0;
    padding: 1rem 1.25rem;
    background: hsl(260 40% 10%);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    overflow-x: auto;
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .docs-code code {
    font-family: var(--font-mono);
    font-size: inherit;
    padding: 0;
    background: none;
    border-radius: 0;
  }

  .docs-table-wrap {
    overflow-x: auto;
  }

  .docs-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8125rem;
    margin-top: 0.5rem;
  }

  .docs-table th {
    text-align: left;
    font-weight: 600;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted-foreground);
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .docs-table td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    color: var(--muted-foreground);
  }

  .docs-table td code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 0.1em 0.35em;
    background: var(--muted);
    border-radius: var(--radius-sm);
  }

  /* ── Empty state ───────────────────────────── */
  .empty-projects {
    padding: 1.5rem;
    background: var(--card);
    border: 1px dashed var(--border);
    border-radius: var(--radius-md);
  }

  .empty-projects p {
    margin: 0 0 0.5rem;
    color: var(--muted-foreground);
  }

  .empty-hint {
    font-size: 0.875rem;
  }

  .empty-hint code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 0.15em 0.4em;
    background: var(--muted);
    border-radius: var(--radius-sm);
  }
</style>
