---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Sign in" description="Sign in to dc_dev">
  <section class="login-section">
    <h1 class="login-title">Sign in</h1>
    <p class="login-subtitle">
      Authentication can be wired to your preferred provider (e.g. Cloudflare Access, OAuth, or custom).
    </p>

    <form class="login-form" action="#" method="post">
      <div class="form-group">
        <label for="email">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="you@example.com"
          required
          autocomplete="email"
        />
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          placeholder="••••••••"
          required
          autocomplete="current-password"
        />
      </div>
      <button type="submit" class="btn btn-primary btn-full">Sign in</button>
    </form>

    <p class="login-note">
      This is a placeholder form. Connect Cloudflare Pages Functions, Workers, or an external auth service to enable real sign-in.
    </p>
  </section>
</BaseLayout>

<style>
  .login-section {
    max-width: 400px;
    margin: 0 auto;
  }

  .login-title {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0 0 0.5rem;
  }

  .login-subtitle {
    color: var(--muted-foreground);
    font-size: 0.875rem;
    margin: 0 0 1.5rem;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-group label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--muted-foreground);
  }

  .form-group input {
    height: 36px;
    padding: 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    background: var(--input);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--foreground);
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .form-group input::placeholder {
    color: var(--muted-foreground);
    opacity: 0.7;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--ring);
    box-shadow: 0 0 0 2px var(--primary-glow);
  }

  .btn-full {
    width: 100%;
    margin-top: 0.5rem;
  }

  .login-note {
    margin-top: 1.5rem;
    padding: 1rem;
    font-size: 0.75rem;
    color: var(--muted-foreground);
    background: var(--card);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--primary);
  }
</style>
