---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Sign in" description="Sign in to dc_dev">
  <section class="login-section">
    <h1 class="login-title">Sign in</h1>
    <p class="login-subtitle">
      Request access below. Once approved, you'll receive a magic link to sign in.
    </p>

    <div id="login-message" class="login-message" style="display: none"></div>

    <form id="request-form" class="login-form">
      <div class="form-group">
        <label for="email">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="you@example.com"
          required
          autocomplete="email"
        />
      </div>
      <div class="form-group">
        <label for="message">Message (optional)</label>
        <input
          type="text"
          id="message"
          name="message"
          placeholder="Why you need access"
          autocomplete="off"
        />
      </div>
      <button type="submit" class="btn btn-primary btn-full">Request access</button>
    </form>

    <p class="login-note">
      If you've been approved, check your email or ask the admin for your magic link.
    </p>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById("request-form")!;
  const messageEl = document.getElementById("login-message")!;
  const apiBase = window.location.origin.includes("workers.dev") ? "" : "https://dc-dev-gateway.masterxavuga.workers.dev";

  const params = new URLSearchParams(window.location.search);
  const error = params.get("error");
  if (error === "expired") {
    messageEl.textContent = "That link has expired. Request a new one.";
    messageEl.className = "login-message error";
    messageEl.style.display = "block";
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = (form.querySelector("#email") as HTMLInputElement).value.trim();
    const message = (form.querySelector("#message") as HTMLInputElement).value.trim();
    const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = "Submitting…";

    try {
      const res = await fetch(`${apiBase}/api/request-access`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, message }),
      });
      const data = await res.json();

      if (res.ok && data.ok) {
        messageEl.textContent = "Request submitted. You'll get access when approved.";
        messageEl.className = "login-message success";
        messageEl.style.display = "block";
        form.reset();
      } else {
        messageEl.textContent = data.error || "Something went wrong.";
        messageEl.className = "login-message error";
        messageEl.style.display = "block";
      }
    } catch {
      messageEl.textContent = "Network error. Try again.";
      messageEl.className = "login-message error";
      messageEl.style.display = "block";
    } finally {
      btn.disabled = false;
      btn.textContent = "Request access";
    }
  });
</script>

<style>
  .login-section {
    max-width: 400px;
    margin: 0 auto;
  }

  .login-title {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0 0 0.5rem;
  }

  .login-subtitle {
    color: var(--muted-foreground);
    font-size: 0.875rem;
    margin: 0 0 1.5rem;
  }

  .login-message {
    padding: 0.75rem;
    border-radius: var(--radius-sm);
    margin-bottom: 1rem;
    font-size: 0.875rem;
  }

  .login-message.success {
    background: color-mix(in srgb, var(--secondary) 20%, var(--card));
    border: 1px solid var(--secondary);
    color: var(--secondary);
  }

  .login-message.error {
    background: color-mix(in srgb, var(--destructive) 15%, var(--card));
    border: 1px solid var(--destructive);
    color: var(--destructive);
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-group label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--muted-foreground);
  }

  .form-group input {
    height: 36px;
    padding: 0 1rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    background: var(--input);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--foreground);
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .form-group input::placeholder {
    color: var(--muted-foreground);
    opacity: 0.7;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--ring);
    box-shadow: 0 0 0 2px var(--primary-glow);
  }

  .btn-full {
    width: 100%;
    margin-top: 0.5rem;
  }

  .login-note {
    margin-top: 1.5rem;
    padding: 1rem;
    font-size: 0.75rem;
    color: var(--muted-foreground);
    background: var(--card);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--primary);
  }
</style>
